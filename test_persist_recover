#!/usr/bin/env bash
set -euo pipefail

# =========================
# CONFIG
# =========================
NES_ROOT="$HOME/nebulastreamBDSPRO"
STORE_DIR="/tmp/nes-worker-store"
IMAGE="nebulastream/nes-development:local"

WORKER_BIN="/nes/cmake-build/nes-single-node-worker/nes-single-node-worker"
REPL_BIN="/nes/cmake-build/nes-nebuli/apps/nes-repl-embedded"

WORKER_PORT=8080

# =========================
# CLEAN-UP
# =========================

rm -rf {STORE_DIR}

# =========================
# START WORKER
# =========================
echo "==> Starting worker"
docker run --rm -d \
  --name nes-worker-test \
  -v "${NES_ROOT}:/nes" \
  -v "${STORE_DIR}:${STORE_DIR}" \
  -p ${WORKER_PORT}:${WORKER_PORT} \
  "${IMAGE}" \
  ${WORKER_BIN} \
    --queryPlanStoreDir=${STORE_DIR}

sleep 3

echo "==> Worker logs (startup)"
docker logs nes-worker-test | tail -n 20

# =========================
# SUBMIT QUERY (TO WORKER!)
# =========================
cat <<'SQL' | docker run --rm -i \
  -v "${NES_ROOT}:/nes" \
  --workdir /nes \
  "${IMAGE}" \
  ${REPL_BIN} \

CREATE LOGICAL SOURCE endless(ts UINT64);

CREATE PHYSICAL SOURCE FOR endless
TYPE Generator
SET(
    'ALL' as `SOURCE`.STOP_GENERATOR_WHEN_SEQUENCE_FINISHES,
    'CSV' as PARSER.`TYPE`,
    'emit_rate 10' AS `SOURCE`.GENERATOR_RATE_CONFIG,
    10000000 AS `SOURCE`.MAX_RUNTIME_MS,
    1 AS `SOURCE`.SEED,
    'SEQUENCE UINT64 0 10000000 1' AS `SOURCE`.GENERATOR_SCHEMA
);

CREATE SINK someSink(ENDLESS.TS UINT64)
TYPE File
SET(
    'out.csv' as `SINK`.FILE_PATH,
    'CSV' as `SINK`.INPUT_FORMAT
);

SELECT TS FROM ENDLESS INTO SOMESINK;
SQL


# =========================
# OPTIONAL DEBUG RENAME (AFTER RECOVERY)
# =========================
cd {STORE_DIR} && mv "$(ls)" "$(uuidgen)"

# =========================
# VERIFY PERSISTENCE
# =========================
echo
echo "==> Persisted state on host (${STORE_DIR})"
find "${STORE_DIR}" -maxdepth 4 -print || true

echo
echo "==> Worker logs after submission"
docker logs nes-worker-test | tail -n 50

# =========================
# CRASH WORKER
# =========================
echo
echo "==> Crashing worker"
docker kill nes-worker-test
sleep 2

# =========================
# RESTART WORKER
# =========================
echo "==> Restarting worker"
docker run --rm -d \
  --name nes-worker-test \
  -v "${NES_ROOT}:/nes" \
  -v "${STORE_DIR}:${STORE_DIR}" \
  -p ${WORKER_PORT}:${WORKER_PORT} \
  "${IMAGE}" \
  ${WORKER_BIN} \
    --queryPlanStoreDir=${STORE_DIR}

sleep 3

echo
echo "==> Worker logs after restart (recovery)"
docker logs nes-worker-test | tail -n 100

# =========================
# FINAL CHECK
# =========================
echo
echo "==> Final persisted state (should be unchanged)"
find "${STORE_DIR}" -maxdepth 4 -print || true

echo
echo "==> DONE: persistence + recovery test completed"
